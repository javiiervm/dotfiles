{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "cssPriority": "user",

  "control-center-width": 380,
  "control-center-height": 860, 
  "control-center-margin-top": 2,
  "control-center-margin-bottom": 2,
  "control-center-margin-right": 1,
  "control-center-margin-left": 0,

  "notification-window-width": 400,
  "notification-icon-size": 48,
  "notification-body-image-height": 0,
  "notification-body-image-width": 0,

  "timeout": 4,
  "timeout-low": 2,
  "timeout-critical": 6,
  
  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 100,
  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,

  "scripts": {
    "play-sound-normal": {
      "exec": "paplay /usr/share/sounds/freedesktop/stereo/message.oga",
      "run-on": "receive",
      "urgency": "Normal"
    },
    "play-sound-critical": {
      "exec": "paplay /usr/share/sounds/freedesktop/stereo/dialog-error.oga",
      "run-on": "receive",
      "urgency": "Critical"
    }
  },

  "widgets": [
    "mpris",
    "buttons-grid",
    "volume",
    "backlight",
    "title",
    "notifications",
    "dnd"
  ],

  "widget-config": {
    "mpris": {
      "image-size": 60,
      "image-radius": 12,
      "show-album-art": "playing",
      "blacklist": [
        "firefox",
        "chromium",
        "brave",
        "mpv",
        "playerctl"
      ],
      "autohide": true,
      "prefer": ["spotify"]
    },
    "buttons-grid": {
      "actions": [
        { "label": "󰖩", "command": ":" },
        { "label": "󰂯", "command": ":" },
        { "label": "󰀝", "command": ":" },
        { "label": "󰂚", "command": ":" },
        { "label": "󰈈", "command": ":" },
        { "label": "", "command": ":" }
      ]
    },
    "volume": {
      "label": "󰕾 ",
      "show-per-app": false
    },
    "backlight": {
      "label": "󰃠 ",
      "device": "amdgpu_bl1",
      "subsystem": "backlight", 
      "min": 10
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All "
    },
    "dnd": {
      "text": "Do not disturb",
      "do-not-disturb-on-startup": false,
      "do-not-disturb": false
    }
  }
}